{
  "name": "rescript-surrealdb",
  "version": "0.0.1-alpha.1",
  "description": "ReScript bindings for the public SurrealDB JavaScript SDK",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/em/rescript-surrealdb",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/em/rescript-surrealdb.git"
  },
  "bugs": {
    "url": "https://github.com/em/rescript-surrealdb/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "rescript",
    "surrealdb",
    "bindings",
    "database",
    "sdk"
  ],
  "files": [
    "README.md",
    "rescript.json",
    "src/**/*.js",
    "src/**/*.mjs",
    "src/**/*.res",
    "src/**/*.resi"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./src/Surrealdb.mjs",
      "default": "./src/Surrealdb.mjs"
    },
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "node ./scripts/rescriptBuild.mjs",
    "verify:generated": "npm run build && git diff --exit-code -- ':(glob)src/**/*.mjs' ':(glob)tests/**/*.mjs'",
    "changeset": "changeset",
    "clean": "rescript clean",
    "db:start": "surreal start --user root --pass root --bind 127.0.0.1:8787 --log info --no-banner rocksdb://dv",
    "release": "echo 'Local publishing disabled. GitHub Actions handles releases from main.' && exit 1",
    "release:ci": "npm publish --access public --provenance --tag \"$(node -p \"require('./package.json').version.match(/-([a-z]+)/)?.[1] || 'latest'\"  )\"",
    "test": "npm run build && vitest run --config vitest.config.js --coverage",
    "test:unit": "npm run build && vitest run --config vitest.unit.config.js",
    "test:live": "npm run build && vitest run --config vitest.live.config.js",
    "test:watch": "vitest --config vitest.config.js",
    "test:unit:watch": "vitest --config vitest.unit.config.js",
    "test:live:watch": "vitest --config vitest.live.config.js",
    "version-packages": "changeset version && npm install --package-lock-only"
  },
  "dependencies": {
    "@rescript/runtime": "12.2.0",
    "rescript-vitest": "^2.1.1",
    "rescript-webapi": "^0.10.0"
  },
  "peerDependencies": {
    "surrealdb": "^2.0.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@vitest/coverage-v8": "^3.1.4",
    "rescript": "12.2.0",
    "rescript-nodejs": "^16.1.0",
    "surrealdb": "^2.0.3",
    "vite": "^6.4.2",
    "vitest": "^3.1.4",
    "ws": "^8.20.0"
  }
}
